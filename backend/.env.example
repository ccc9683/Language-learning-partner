LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Optional: used by Partner voice upload fallback when browser speech recognition fails.
# If omitted, backend falls back to LLM_API_KEY, but the provider must support audio transcriptions.
STT_API_KEY=
STT_BASE_URL=
STT_MODEL=whisper-1
