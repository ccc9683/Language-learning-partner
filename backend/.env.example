LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Local speech-to-text for Partner voice input.
# LOCAL_STT_MODEL can be tiny/base/small/medium/large-v3 or a local model path.
LOCAL_STT_MODEL=base
LOCAL_STT_MODEL_PATH=
LOCAL_STT_CACHE_DIR=
LOCAL_STT_DEVICE=cpu
LOCAL_STT_COMPUTE_TYPE=int8
LOCAL_STT_LANGUAGE=
LOCAL_STT_BEAM_SIZE=1
